---
import Icon from '../shared/Icon.astro';

const navItems = [
  { href: '/work',     label: 'Work' },
  { href: '/projects', label: 'Projects' },
  { href: '/writing',  label: 'Writing', soon: true },
  { href: '/uses',     label: 'Uses' },
  { href: '/contact',  label: 'Contact' },
];

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${basePath}${path === '/' ? '/' : path}`;
const routePathname = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || '/'
  : Astro.url.pathname;
const pathname = routePathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';
---

<nav class:list={['site-nav', { 'is-solid': !isHome }]} data-home={String(isHome)}>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <div class="container-page nav-inner">
    <a href={withBase('/')} class="logo" aria-label="Rishabh home">R<span>.</span></a>

    <button
      class="menu-button"
      type="button"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-button
    >
      <span></span>
      <span></span>
    </button>

    <div class="desktop-links" aria-label="Primary navigation">
      {navItems.map((item) => {
        const active = item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
        return item.soon ? (
          <span class="nav-link nav-soon" title="Coming soon" aria-label={`${item.label}, coming soon`}>
            {item.label}
          </span>
        ) : (
          <a class:list={['nav-link', { active }]} href={withBase(item.href)}>
            {item.label}
          </a>
        );
      })}
      <a
        href="https://drive.google.com/file/d/1iUQMhulzHFFhTT7vyYKTaEtv5EXFFXSw/view?usp=sharing"
        target="_blank"
        rel="noreferrer"
        class="nav-resume"
      >
        <Icon name="download" size={13} /> Resume
      </a>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" data-mobile-menu aria-hidden="true">
    <div class="mobile-menu-inner">
      <button class="close-button" type="button" aria-label="Close navigation" data-close-button>
        Close
      </button>
      {navItems.map((item) => {
        const active = item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
        return item.soon ? (
          <span class:list={['mobile-link', 'mobile-link-soon']}>
            {item.label} <small>soon</small>
          </span>
        ) : (
          <a class:list={['mobile-link', { active }]} href={withBase(item.href)}>
            {item.label}
          </a>
        );
      })}
      <a
        href="https://drive.google.com/file/d/1iUQMhulzHFFhTT7vyYKTaEtv5EXFFXSw/view?usp=sharing"
        target="_blank"
        rel="noreferrer"
        class="mobile-link nav-resume-mobile"
      >
        <Icon name="download" size={16} /> Download Resume
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>('.site-nav');
  const menuButton = document.querySelector<HTMLButtonElement>('[data-menu-button]');
  const closeButton = document.querySelector<HTMLButtonElement>('[data-close-button]');
  const mobileMenu = document.querySelector<HTMLElement>('[data-mobile-menu]');

  const updateNav = () => {
    if (!nav) return;
    const isHome = nav.dataset.home === 'true';
    nav.classList.toggle('is-solid', !isHome || window.scrollY > 60);
  };

  let menuIsOpen = false;

  const setMenuOpen = (open: boolean) => {
    if (!menuButton || !mobileMenu) return;
    menuIsOpen = open;
    menuButton.setAttribute('aria-expanded', String(open));
    menuButton.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
    mobileMenu.setAttribute('aria-hidden', String(!open));
    document.documentElement.classList.toggle('menu-open', open);
  };

  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });
  menuButton?.addEventListener('click', () => setMenuOpen(!menuIsOpen));
  closeButton?.addEventListener('click', () => setMenuOpen(false));
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });
  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMenuOpen(false);
  });
</script>

<style>
  .site-nav {
    position: fixed;
    z-index: 40;
    top: 0;
    right: 0;
    left: 0;
    border-bottom: 1px solid transparent;
    background: transparent;
    transition:
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .site-nav.is-solid {
    border-color: var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
  }

  @supports (backdrop-filter: blur(1px)) {
    .site-nav.is-solid {
      backdrop-filter: blur(14px);
    }
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 60;
    transform: translateY(-150%);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    color: var(--color-text-primary);
    font-size: 0.875rem;
    padding: 0.65rem 0.85rem;
    transition: transform 160ms ease;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .nav-inner {
    display: flex;
    min-height: 72px;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    color: var(--color-text-primary);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .logo span {
    color: var(--color-accent);
  }

  .desktop-links {
    display: none;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    position: relative;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    transition: all 160ms ease;
  }

  .nav-soon {
    color: var(--color-text-tertiary);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    cursor: default;
    opacity: 0.55;
    user-select: none;
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-secondary);
  }

  .nav-soon:hover {
    color: var(--color-text-tertiary);
    background: transparent;
  }

  .nav-link.active {
    color: var(--color-bg);
    background: var(--color-text-primary);
  }

  .nav-resume {
    background: var(--color-text-primary);
    color: var(--color-bg);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    transition: all 160ms ease;
    text-decoration: none;
    box-shadow: 0 1px 3px rgba(26, 23, 20, 0.18);
    margin-left: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-resume:hover {
    transform: translateY(-1px);
    background: #2d2a26;
    color: var(--color-bg);
    box-shadow: 0 4px 12px rgba(26, 23, 20, 0.25);
  }

  .nav-link:focus-visible,
  .nav-resume:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .nav-resume-mobile {
    margin-top: 1rem;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .menu-button {
    display: inline-flex;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.35rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: transparent;
    color: var(--color-text-primary);
    cursor: pointer;
  }

  .menu-button span {
    width: 1rem;
    height: 1px;
    background: currentColor;
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: grid;
    min-height: 100vh;
    min-height: 100dvh;
    background: var(--color-bg);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 180ms ease, visibility 180ms ease;
  }

  .mobile-menu[aria-hidden='false'] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-menu-inner {
    display: flex;
    width: min(100% - 2rem, 36rem);
    margin: 0 auto;
    padding: calc(1.25rem + env(safe-area-inset-top, 0)) 0 calc(4rem + env(safe-area-inset-bottom, 0));
    flex-direction: column;
    gap: 1.25rem;
  }

  .close-button {
    align-self: flex-end;
    min-width: 2.75rem;
    min-height: 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0.65rem 0.85rem;
  }

  .mobile-link {
    color: var(--color-text-primary);
    font-size: clamp(2rem, 13vw, 4.5rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  .mobile-link.active {
    color: var(--color-accent);
  }

  .mobile-link-soon {
    color: var(--color-text-tertiary);
    font-size: clamp(2rem, 13vw, 4.5rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 0.95;
    opacity: 0.4;
    cursor: default;
    user-select: none;
  }

  .mobile-link-soon small {
    font-size: 0.5em;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-left: 0.5rem;
    font-family: 'Geist Mono', monospace;
  }

  :global(.menu-open) {
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .desktop-links {
      display: flex;
    }

    .menu-button {
      display: none;
    }
  }
</style>
