---
import Tag from './Tag.astro';

interface Props {
  company: string;
  title: string;
  summary: string;
  impact?: string;
  tags?: readonly string[];
}

const { company, title, summary, impact, tags = [] } = Astro.props;
---

<article class="work-card">
  <div class="work-card-head">
    <p class="text-mono work-company">{company}</p>
    {impact && <p class="work-impact">{impact}</p>}
  </div>
  <h3 class="work-title">{title}</h3>
  <p class="text-body work-summary">{summary}</p>
  {tags.length > 0 && (
    <div class="work-tags">
      {tags.map((tag) => (
        <Tag>{tag}</Tag>
      ))}
    </div>
  )}
</article>

<style>
  .work-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    padding: 1.75rem;
    transition:
      border-color 180ms ease,
      transform 180ms ease;
  }

  .work-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 35%, var(--color-border));
    transform: translateY(-2px);
  }

  .work-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .work-company {
    margin: 0;
  }

  .work-impact {
    color: var(--color-accent-text);
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .work-title {
    color: var(--color-text-primary);
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }

  .work-summary {
    margin: 0;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
</style>
