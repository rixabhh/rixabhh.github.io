---
import Tag from './Tag.astro';
import Icon from './Icon.astro';

interface Props {
  company: string;
  title: string;
  summary: string;
  impact?: string;
  tags?: readonly string[];
  index?: number;
  href?: string;
}

const { company, title, impact, tags = [], index, href } = Astro.props;
const num = index ? String(index).padStart(2, '0') : undefined;
---

<article class="work-row">
  <a class="work-row-link" href={href ?? '#'} aria-label={`View case study: ${title}`}>
    {num && <span class="work-num" aria-hidden="true">{num}</span>}
    <div class="work-center">
      <div class="work-meta">
        <p class="text-mono work-company">{company}</p>
      </div>
      <h3 class="work-title">{title}</h3>
      {tags.length > 0 && (
        <div class="work-tags">
          {tags.map((tag) => (
            <Tag>{tag}</Tag>
          ))}
        </div>
      )}
    </div>
    <div class="work-right">
      {impact && <p class="work-impact">{impact}</p>}
      <span class="work-arrow" aria-hidden="true"><Icon name="arrow-right" size={18} /></span>
    </div>
  </a>
</article>

<style>
  .work-row {
    border-top: 1px solid var(--color-border);
  }

  .work-row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .work-row-link {
    display: grid;
    grid-template-columns: 3.5rem 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem 0.5rem;
    color: inherit;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      padding-left 180ms ease;
    border-radius: 0.25rem;
    position: relative;
  }

  .work-row-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 220ms ease;
    pointer-events: none;
  }

  .work-row:hover .work-row-link {
    background: var(--color-bg-secondary);
    padding-left: 1.25rem;
  }

  .work-row:hover .work-row-link::before {
    transform: scaleY(1);
  }

  .work-row:hover .work-arrow {
    transform: translateX(5px);
    color: var(--color-accent);
  }

  /* Large index number */
  .work-num {
    font-family: 'Geist', system-ui, sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    user-select: none;
    -webkit-text-stroke: 1px var(--color-border-strong);
    color: transparent;
    transition: -webkit-text-stroke-color 200ms ease;
  }

  .work-row:hover .work-num {
    -webkit-text-stroke-color: var(--color-accent);
  }

  /* Center column */
  .work-center {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .work-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .work-company {
    margin: 0;
    color: var(--color-text-tertiary);
  }

  .work-title {
    color: var(--color-text-primary);
    font-family: 'Geist', system-ui, sans-serif;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin: 0;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* Right column */
  .work-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    min-width: 10rem;
    text-align: right;
  }

  .work-impact {
    color: var(--color-text-secondary);
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.5;
  }

  .work-arrow {
    color: var(--color-text-tertiary);
    display: flex;
    align-items: center;
    transition:
      transform 180ms ease,
      color 180ms ease;
  }

  /* Mobile: stack layout */
  @media (max-width: 600px) {
    .work-row {
      overflow: hidden;
    }

