---
interface Props {
  value: string;
  label: string;
  detail?: string;
  highlight?: boolean; // dark filled center cell
}

const { value, label, detail, highlight = false } = Astro.props;
---

<article class:list={['metric-card', { highlight }]}>
  <p class="metric-value">{value}</p>
  <p class="metric-label">{label}</p>
  {detail && <p class="metric-detail">{detail}</p>}
</article>

<style>
  .metric-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 2rem 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition:
      border-color 200ms ease,
      transform 200ms ease,
      box-shadow 200ms ease;
    position: relative;
  }

  @media (max-width: 600px) {
    .metric-card {
      padding: 1.5rem 1.25rem;
    }
  }

  .metric-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 1.75rem;
    right: 1.75rem;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 220ms ease;
  }

  .metric-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(26, 23, 20, 0.08);
  }

  .metric-card:hover::after {
    transform: scaleX(1);
  }

  /* Highlight (dark) variant for center cell */
  .metric-card.highlight {
    background: var(--color-text-primary);
    border-color: var(--color-text-primary);
  }

  .metric-card.highlight .metric-value {
    color: #fff;
  }

  .metric-card.highlight .metric-label {
    color: rgba(255, 255, 255, 0.75);
  }

  .metric-card.highlight .metric-detail {
    color: rgba(255, 255, 255, 0.45);
  }

  .metric-card.highlight::after {
    background: rgba(255, 255, 255, 0.3);
  }

  .metric-value {
    color: var(--color-accent);
    font-family: 'Geist', system-ui, sans-serif;
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0;
  }

  .metric-label {
    color: var(--color-text-primary);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
    margin-top: 0.25rem;
  }

  .metric-detail {
    color: var(--color-text-tertiary);
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    line-height: 1.5;
    margin: 0;
    margin-top: 0.35rem;
    text-transform: uppercase;
  }
</style>
