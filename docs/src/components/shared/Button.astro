---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'text' | 'pill' | 'pill-outline';
  id?: string;
}

const { href, variant = 'primary', id } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolvedHref = href.startsWith('/')
  ? `${basePath}${href === '/' ? '/' : href}`
  : href;
---

<a class:list={['button', variant]} href={resolvedHref} id={id}>
  <slot />
</a>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.75rem 1.25rem;
    border-radius: 0.5rem;
    min-height: 2.75rem;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
    -webkit-tap-highlight-color: transparent;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button:active {
    transform: translateY(0);
  }

  /* ── Filled primary ── */
  .primary {
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 1px 2px rgba(200, 57, 43, 0.25);
  }

  .primary:hover {
    background: var(--color-accent-hover);
    box-shadow: 0 4px 12px rgba(200, 57, 43, 0.3);
  }

  /* ── Outlined secondary ── */
  .secondary {
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
  }

  .secondary:hover {
    background: var(--color-accent-subtle);
    border-color: var(--color-accent-hover);
  }

  /* ── Text link ── */
  .text {
    min-height: 2.5rem;
    display: inline-flex;
    align-items: center;
    color: var(--color-accent);
    padding: 0.5rem 0;
    border-radius: 0;
  }

  .text:hover {
    color: var(--color-accent-hover);
    transform: none;
  }

  /* ── Pill filled ── */
  .pill {
    background: var(--color-accent);
    color: #fff;
    border-radius: 999px;
    padding: 0.75rem 1.75rem;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    box-shadow: 0 2px 6px rgba(200, 57, 43, 0.3);
  }

  .pill:hover {
    background: var(--color-accent-hover);
    box-shadow: 0 6px 18px rgba(200, 57, 43, 0.4);
  }

  /* ── Pill outlined ── */
  .pill-outline {
    border: 2px solid var(--color-text-primary);
    color: var(--color-text-primary);
    background: transparent;
    border-radius: 999px;
    padding: 0.75rem 1.75rem;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
  }

  .pill-outline:hover {
    background: var(--color-text-primary);
    color: var(--color-bg);
  }

  .button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .pill:focus-visible,
  .pill-outline:focus-visible {
    border-radius: 999px;
  }
</style>
