---
import Layout from '../components/layout/Layout.astro';
import Button from '../components/shared/Button.astro';
---

<Layout>
  <section class="container-page hero-shell">
    <div class="hero-copy">
      <p class="text-mono">APM · AI Products · Systems</p>
      <h1 class="text-display">I build AI products and the systems that make them work.</h1>
      <p class="text-body">
        Assistant Product Manager at Amkette (EvoFox). I work at the intersection of AI,
        automation, and customer experience.
      </p>
      <div class="hero-actions">
        <Button href="/work">See my work</Button>
        <Button href="/contact" variant="secondary">Book a call</Button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-shell {
    display: grid;
    min-height: 88vh;
    align-items: center;
    padding-top: 7rem;
  }

  .hero-copy {
    max-width: 760px;
  }

  .hero-copy h1 {
    margin: 1rem 0 1.5rem;
  }

  .hero-copy p:last-of-type {
    max-width: 620px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
</style>
