---
import Layout from '../components/layout/Layout.astro';
import Button from '../components/shared/Button.astro';
import Portrait from '../components/shared/Portrait.astro';
import MetricCard from '../components/shared/MetricCard.astro';
import WorkCard from '../components/shared/WorkCard.astro';
import MarqueeStrip from '../components/shared/MarqueeStrip.astro';
import Icon from '../components/shared/Icon.astro';
import { site, metrics, workItems } from '../data/site';
---

<Layout>
  <!-- ═══════════════════════════════════════
       HERO
  ═══════════════════════════════════════ -->
  <section class="hero-section container-page">
    <div class="hero-grid">
      <!-- Left: copy -->
      <div class="hero-copy animate-hero-copy">
        <p class="hero-eyebrow text-mono">APM · AI Products · B2B SaaS</p>
        <h1 class="hero-headline">
          {site.tagline}
        </h1>
        <p class="hero-lead text-body">
          {site.role}. I work at the intersection of AI, automation, and
          customer experience, from discovery and specs to shipped systems
          with measurable impact.
        </p>
        <div class="hero-actions">
          <Button href="/work" variant="pill" id="hero-cta-work">See my work</Button>
          <Button href="/contact" variant="pill-outline" id="hero-cta-contact">Get in touch</Button>
          <Button href="https://drive.google.com/file/d/1iUQMhulzHFFhTT7vyYKTaEtv5EXFFXSw/view?usp=sharing" variant="pill-outline" id="hero-cta-resume"><Icon name="download" size={14} /> Resume</Button>
        </div>

        <!-- Inline status strip -->
        <p class="hero-status text-mono">
          <span class="status-dot" aria-hidden="true"></span>
          Available for APM/PM roles &amp; mentorship bookings
        </p>
      </div>

      <!-- Right: portrait -->
      <div class="hero-visual animate-hero-image">
        <Portrait priority />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       MARQUEE TICKER STRIP
  ═══════════════════════════════════════ -->
  <MarqueeStrip />

  <!-- ═══════════════════════════════════════
       METRICS ROW
  ═══════════════════════════════════════ -->
  <section class="section-block metrics-section" aria-label="Key metrics">
    <div class="container-page">
      <div class="metrics-header section-heading reveal">
        <div class="section-heading-copy">
          <p class="text-mono">Impact</p>
          <h2 class="text-heading">Outcomes that matter</h2>
        </div>
      </div>
      <div class="metrics-row">
        <MetricCard
          value={metrics[0].value}
          label={metrics[0].label}
          detail={metrics[0].detail}
        />
        <MetricCard
          value={metrics[1].value}
          label={metrics[1].label}
          detail={metrics[1].detail}
          highlight
        />
        <MetricCard
          value={metrics[2].value}
          label={metrics[2].label}
          detail={metrics[2].detail}
        />
        <MetricCard
          value={metrics[3].value}
          label={metrics[3].label}
          detail={metrics[3].detail}
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       ABOUT
  ═══════════════════════════════════════ -->
  <section class="section-block about-section">
    <div class="container-page">
      <div class="about-layout">
        <div class="about-left reveal">
          <p class="text-mono">About</p>
          <h2 class="text-heading about-headline">
            Product at the edge of engineering.
          </h2>
        </div>
        <div class="about-right reveal reveal-delay-1">
          <p class="text-body about-lead">{site.bio}</p>
          <div class="about-meta-row">
            <div class="about-meta-item">
              <span class="text-mono about-meta-label"><Icon name="briefcase" size={13} /> Current</span>
              <span class="about-meta-value">Amkette (EvoFox)</span>
            </div>
            <div class="about-meta-item">
              <span class="text-mono about-meta-label"><Icon name="graduation-cap" size={13} /> Education</span>
              <span class="about-meta-value">{site.education}</span>
            </div>
            <div class="about-meta-item">
              <span class="text-mono about-meta-label"><Icon name="map-pin" size={13} /> Based in</span>
              <span class="about-meta-value">India</span>
            </div>
          </div>
          <a
            href="https://drive.google.com/file/d/1iUQMhulzHFFhTT7vyYKTaEtv5EXFFXSw/view?usp=sharing"
            target="_blank"
            rel="noreferrer"
            class="resume-link text-mono"
            id="resume-download"
          >
            <Icon name="download" size={12} /> Download Resume
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CAREER TRAJECTORY
  ═══════════════════════════════════════ -->
  <section class="section-block career-section">
    <div class="container-page">
      <div class="section-heading">
        <div class="section-heading-copy">
          <p class="text-mono">Experience</p>
          <h2 class="text-heading">Career trajectory</h2>
        </div>
      </div>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-dot timeline-dot-current"></span>
            <span class="timeline-line"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <h3 class="timeline-role">Assistant Product Manager</h3>
                <p class="timeline-company">Amkette (EvoFox)</p>
              </div>
              <span class="timeline-date text-mono">2025 – Present</span>
            </div>
            <ul class="timeline-details">
              <li>Leading CRO strategy and internal CX platform development</li>
              <li>Building AI automation systems with LLM chains and agentic workflows</li>
              <li>Owned product delivery from zero requirements to alpha handoff</li>
            </ul>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-dot"></span>
            <span class="timeline-line"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <h3 class="timeline-role">Product Intern</h3>
                <p class="timeline-company">EshopBox</p>
              </div>
              <span class="timeline-date text-mono">2024</span>
            </div>
            <ul class="timeline-details">
              <li>Shipped WhatsApp Sales Discovery Bot — automated 40% of L1 queries</li>
              <li>Built identity resolution layer restoring CRM accuracy to 95%</li>
              <li>Designed multi-provider LLM lead scoring pipeline</li>
              <li>Launched Eshopbox Plus Kiosk Flow — +25% lead capture uplift</li>
            </ul>
          </div>
        </div>

        <div class="timeline-item timeline-item-education">
          <div class="timeline-marker">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div>
                <h3 class="timeline-role">B.Tech CSE (Data Science)</h3>
                <p class="timeline-company">SIET</p>
              </div>
              <span class="timeline-date text-mono">2023 – 2027</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SELECTED WORK
  ═══════════════════════════════════════ -->
  <section class="section-block work-section">
    <div class="container-page">
      <div class="section-heading reveal">
        <div class="section-heading-copy">
          <p class="text-mono">Selected work</p>
          <h2 class="text-heading">Case studies from product and ops</h2>
        </div>
        <Button href="/work" variant="text" id="view-all-work">View all work <Icon name="arrow-right" size={14} /></Button>
      </div>

      <div class="work-list" role="list">
        {workItems.slice(0, 4).map((item, i) => (
          <WorkCard
            company={item.company}
            title={item.title}
            summary={item.summary}
            impact={item.impact}
            tags={item.tags}
            index={i + 1}
            href={`/work/${item.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA PANEL
  ═══════════════════════════════════════ -->
  <section class="section-block cta-section">
    <div class="container-page">
      <div class="cta-panel reveal">
        <div class="cta-copy">
          <p class="text-mono">Connect</p>
          <h2 class="text-heading cta-headline">Open to product conversations.</h2>
          <p class="text-body cta-body">
            Whether you're hiring, collaborating, or just want to talk AI products. I'd love to hear from you.
          </p>
          <ul class="open-to-list" aria-label="Open to">
            <li><Icon name="briefcase" size={14} class:list={['open-icon']} /> APM / PM roles, India and global</li>
            <li><Icon name="users" size={14} class:list={['open-icon']} /> B2B SaaS product consulting</li>
            <li><Icon name="graduation-cap" size={14} class:list={['open-icon']} /> Mentorship for early-career PMs</li>
          </ul>
        </div>
        <div class="cta-actions">
          <Button href="/contact" variant="pill" id="cta-lets-talk">Let's talk</Button>
          <Button href={`mailto:${site.email}`} variant="pill-outline" id="cta-email">Email me</Button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero-section {
    min-height: calc(100vh - 72px);
    min-height: calc(100dvh - 72px);
    display: flex;
    align-items: center;
    padding-top: 7rem;
    padding-bottom: 4rem;
  }

  .hero-grid {
    display: grid;
    align-items: center;
    gap: 3rem;
    width: 100%;
  }

  .hero-copy {
    max-width: 700px;
  }

  .hero-eyebrow {
    margin: 0 0 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-headline {
    font-family: 'Geist', system-ui, sans-serif;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
  }

  .hero-lead {
    max-width: 560px;
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.25rem;
  }

  .hero-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1.75rem 0 0;
    font-size: 0.68rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.1em;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.3); }
  }

  .hero-visual {
    width: min(100%, 22rem);
    margin-inline: auto;
  }

  @media (max-width: 480px) {
    .hero-visual {
      width: 14rem;
    }
  }

  /* Hero entrance animations */
  .animate-hero-copy {
    animation: fadeUp 0.6s ease both;
    animation-delay: 200ms;
  }

  .animate-hero-image {
    animation: scaleIn 0.6s ease both;
    animation-delay: 400ms;
  }

  /* ── Metrics ── */
  .metrics-section {
    padding-bottom: 0;
  }

  @media (max-width: 600px) {
    .metrics-section {
      padding-bottom: 1rem;
    }
  }

  .metrics-header {
    margin-bottom: 2rem;
  }

  .metrics-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .metrics-row > :global(*) {
    border-radius: 0 !important;
    border: none !important;
    border-right: 1px solid var(--color-border) !important;
    border-bottom: 1px solid var(--color-border) !important;
  }

  .metrics-row > :global(*:nth-child(2n)) {
    border-right: none !important;
  }

  .metrics-row > :global(*:nth-last-child(-n+2)) {
    border-bottom: none !important;
  }

  /* ── About ── */
  .about-layout {
    display: grid;
    gap: 2.5rem;
  }

  .about-headline {
    margin-top: 0.75rem;
    max-width: 22rem;
  }

  .about-lead {
    margin: 0;
    font-size: 1.05rem;
  }

  .about-meta-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .about-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .about-meta-label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.65rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: 'Geist Mono', ui-monospace, monospace;
  }

  .about-meta-value {
    font-size: 0.95rem;
    color: var(--color-text-primary);
    font-weight: 500;
    line-height: 1.4;
  }

  .resume-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 1.5rem;
    color: var(--color-accent);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 160ms ease, text-decoration-color 160ms ease;
  }

  .resume-link:hover {
    color: var(--color-accent-hover);
  }

  /* ── Work ── */
  .work-list {
    margin-top: 1rem;
  }

  /* ── Career Timeline ── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 1.25rem;
    padding-bottom: 2.5rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--color-border-strong);
    background: var(--color-bg);
    flex-shrink: 0;
    margin-top: 0.35rem;
  }

  .timeline-dot-current {
    background: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-subtle);
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: var(--color-border);
    margin-top: 0.5rem;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 0;
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .timeline-role {
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .timeline-company {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin: 0.15rem 0 0;
  }

  .timeline-date {
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .timeline-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .timeline-details li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .timeline-details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55rem;
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--color-accent);
  }

  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 1rem 1fr;
      gap: 1rem;
      padding-bottom: 2rem;
    }

    .timeline-header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .timeline-role {
      font-size: 0.95rem;
    }

    .timeline-details li {
      font-size: 0.85rem;
    }
  }

  /* ── CTA Panel ── */
  .cta-panel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    background: var(--color-surface);
    padding: 3rem 3.5rem;
    flex-wrap: wrap;
    position: relative;
  }

  /* Subtle accent corner decoration */
  .cta-panel::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    border-radius: 1.25rem 0 0 1.25rem;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    pointer-events: none;
  }

  .cta-headline {
    margin-top: 0.75rem;
    max-width: 28rem;
  }

  .cta-body {
    margin-top: 1rem;
    max-width: 32rem;
  }

  .open-to-list {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .open-to-list li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .open-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
      gap: 5rem;
      align-items: flex-start;
    }

    .hero-visual {
      width: 100%;
      max-width: 22rem;
      margin-inline: 0 0;
      justify-self: end;
      margin-top: 2rem;
    }

    .about-layout {
      grid-template-columns: 1fr 1.6fr;
      gap: 5rem;
      align-items: start;
    }

    .metrics-row {
      grid-template-columns: repeat(4, 1fr);
    }

    .metrics-row > :global(*) {
      border-bottom: none !important;
      border-right: 1px solid var(--color-border) !important;
    }

    .metrics-row > :global(*:last-child) {
      border-right: none !important;
    }
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .hero-copy {
      display: flex;
      flex-direction: column;
      align-items: center;
      max-width: 100%;
    }

    .hero-eyebrow {
      justify-content: center;
    }

    .hero-lead {
      max-width: 480px;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-status {
      justify-content: center;
    }

    .hero-visual {
      order: 2;
    }

    .about-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 600px) {
    .hero-section {
      padding-top: 5rem;
      padding-bottom: 2.5rem;
    }

    .hero-headline {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .hero-lead {
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .hero-actions {
      margin-top: 1.75rem;
    }

    .about-meta-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .cta-panel {
      padding: 2rem 1.5rem;
    }

    .cta-headline {
      max-width: 100%;
    }

    .cta-actions {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .section-block {
      padding-block: 3rem;
    }

    .metrics-row {
      grid-template-columns: 1fr;
    }

    .metrics-row > :global(*) {
      border-right: none !important;
      border-bottom: 1px solid var(--color-border) !important;
    }

    .metrics-row > :global(*:last-child) {
      border-bottom: none !important;
    }
  }

  @media (max-width: 380px) {
    .hero-section {
      padding-top: 4rem;
      padding-bottom: 2rem;
    }

    .cta-panel {
      padding: 1.5rem 1.25rem;
    }

    .about-layout {
      gap: 2rem;
    }
  }
</style>
