---
import Layout from '../components/layout/Layout.astro';
import PageHeader from '../components/shared/PageHeader.astro';
import Icon from '../components/shared/Icon.astro';
import { usesCategories } from '../data/site';

const categoryIcons: Record<string, string> = {
  'Product and Strategy': 'briefcase',
  'B2B SaaS': 'users',
  'AI, LLM and Automation': 'zap',
  'Engineering': 'code',
  'Data and Instrumentation': 'bar-chart',
};
---

<Layout title="Uses | Rishabh Singh" description="Tools, stack, and workflows for product management, AI systems, and engineering.">
  <section class="container-page page-shell">
    <PageHeader
      label="Stack and tools"
      title="Uses"
      description="The tools and workflows I reach for when building products, automation systems, and data pipelines."
    />

    <div class="grid-uses uses-list reveal">
      {usesCategories.map((category) => (
        <section class="uses-card">
          <h2 class="uses-title">
            {categoryIcons[category.title] && <Icon name={categoryIcons[category.title]} size={16} class="uses-icon" />}
            {category.title}
          </h2>
          <ul class="uses-items">
            {category.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>
</Layout>

<style>
  .uses-list {
    margin-top: 3rem;
  }

  .uses-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    padding: 1.75rem;
    transition:
      border-color 200ms ease,
      transform 200ms ease,
      box-shadow 200ms ease;
  }

  .uses-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 25%, var(--color-border));
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(26, 23, 20, 0.06);
  }

  .uses-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-primary);
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
  }

  .uses-icon {
    color: var(--color-accent);
  }

  .uses-items {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .uses-items li {
    position: relative;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-left: 1rem;
    transition: color 160ms ease;
  }

  .uses-card:hover .uses-items li {
    color: var(--color-text-primary);
  }

  .uses-items li::before {
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--color-accent);
    content: '';
    transition: transform 160ms ease;
  }

  .uses-card:hover .uses-items li::before {
    transform: scale(1.5);
  }

  @media (max-width: 600px) {
    .uses-card {
      padding: 1.5rem 1.25rem;
    }

    .uses-items li {
      font-size: 0.9rem;
      padding-left: 0.875rem;
      min-height: 2rem;
      display: flex;
      align-items: center;
    }
  }
</style>
