---
import Layout from '../components/layout/Layout.astro';
import PageHeader from '../components/shared/PageHeader.astro';
import { usesCategories } from '../data/site';
---

<Layout title="Uses | Rishabh Singh" description="Tools, stack, and workflows for product management, AI systems, and engineering.">
  <section class="container-page page-shell">
    <PageHeader
      label="Stack and tools"
      title="Uses"
      description="The tools and workflows I reach for when building products, automation systems, and data pipelines."
    />

    <div class="grid-uses uses-list">
      {usesCategories.map((category) => (
        <section class="uses-card">
          <h2 class="uses-title">{category.title}</h2>
          <ul class="uses-items">
            {category.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>
</Layout>

<style>
  .uses-list {
    margin-top: 3rem;
  }

  .uses-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    padding: 1.75rem;
  }

  .uses-title {
    color: var(--color-text-primary);
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
  }

  .uses-items {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .uses-items li {
    position: relative;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
    padding-left: 1rem;
  }

  .uses-items li::before {
    position: absolute;
    top: 0.55rem;
    left: 0;
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--color-accent);
    content: '';
  }
</style>
