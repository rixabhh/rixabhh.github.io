---
import Layout from '../components/layout/Layout.astro';
import PageHeader from '../components/shared/PageHeader.astro';
import ProjectCard from '../components/shared/ProjectCard.astro';
import { projects } from '../data/site';
---

<Layout title="Projects | Rishabh Singh" description="Side projects, solo builds, and product systems shipped outside the day job.">
  <section class="container-page page-shell">
    <PageHeader
      label="Builds"
      title="Projects"
      description="Personal builds and product systems, from zero to CI/CD, specs to production."
    />

    <div class="project-list reveal">
      {projects.map((project) => (
        <ProjectCard
          title={project.title}
          summary={project.summary}
          tags={project.tags}
          href={project.href}
        />
      ))}
    </div>
  </section>
</Layout>

<style>
  .project-list {
    display: grid;
    gap: 1rem;
    margin-top: 3rem;
    max-width: 48rem;
  }

  @media (max-width: 600px) {
    .project-list {
      gap: 0.75rem;
    }
  }
</style>
