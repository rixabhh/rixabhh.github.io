---
import Layout from '../../components/layout/Layout.astro';
import SectionLabel from '../../components/shared/SectionLabel.astro';
import PageHeader from '../../components/shared/PageHeader.astro';
import WorkCard from '../../components/shared/WorkCard.astro';
import { workItems } from '../../data/site';
---

<Layout
  title="Work | Rishabh Singh"
  description="Selected product work: AI automation, CX platforms, CRM systems, and conversion optimization."
>
  <SectionLabel label="work" />
  <section class="container-page page-shell">
    <PageHeader
      label="Case studies"
      title="Selected product work"
      description="Product ownership across AI automation, data systems, and customer experience, from spec to shipped impact."
    />

    <div class="work-list" role="list">
      {workItems.map((item, i) => (
        <WorkCard
          company={item.company}
          title={item.title}
          summary={item.summary}
          impact={item.impact}
          tags={item.tags}
          index={i + 1}
          href={`/work/${item.slug}`}
        />
      ))}
    </div>
  </section>
</Layout>

<style>
  .work-list {
    margin-top: 3rem;
  }
</style>
